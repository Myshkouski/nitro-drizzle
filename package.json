{
  "name": "nitro-drizzle",
  "version": "0.2.15",
  "description": "Nitro module to integrate Drizzle ORM with ease.",
  "homepage": "https://github.com/Myshkouski/nitro-drizzle#readme",
  "bugs": {
    "url": "https://github.com/Myshkouski/nitro-drizzle/issues"
  },
  "license": "MIT",
  "author": "Alexei Myshkouski <alexeimyshkouski@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Myshkouski/nitro-drizzle.git"
  },
  "files": [
    "dist"
  ],
  "type": "module",
  "exports": {
    ".": "./dist/index.mjs",
    "./shared": "./dist/shared.mjs",
    "./migrations": "./dist/migrations.mjs",
    "./migrations/task": "./dist/migrations/task.mjs",
    "./config": "./dist/config.mjs",
    "./context": "./dist/context.mjs",
    "./dialects": "./dist/dialects/index.mjs",
    "./dialects/*": "./dist/dialects/*.mjs",
    "./drivers": "./dist/drivers/index.mjs",
    "./drivers/*": "./dist/drivers/*.mjs",
    "./meta": "./dist/meta.mjs",
    "./module": "./dist/module.mjs",
    "./plugins/*": "./dist/plugins/*.mjs",
    "./runtime": "./dist/runtime.mjs",
    "./utils": "./dist/utils.mjs",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "tsdown",
    "build:dev": "tsdown --watch",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "playground": "nitro dev playground",
    "prepare": "lefthook install",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "typecheck:fixtures": "nitro prepare fixtures/blog-api && tsc --noEmit -p fixtures/blog-api/tsconfig.json",
    "release": "changelogen --release"
  },
  "dependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@typescript/native-preview": "7.0.0-dev.20260606.1",
    "c12": "^3.3.4",
    "consola": "^3.4.2",
    "db0": "^0.3.4",
    "defu": "^6.1.7",
    "jiti": "^2.7.0",
    "knitwork": "^1.3.0",
    "nitropack": "catalog:",
    "ohash": "^2.0.11",
    "pathe": "^2.0.3",
    "rollup": "^4.62.2",
    "strip-indent": "^4.1.1",
    "tinyglobby": "^0.2.17",
    "unstorage": "^1.17.5"
  },
  "devDependencies": {
    "@arethetypeswrong/core": "^0.18.4",
    "@testcontainers/mysql": "catalog:testcontainers",
    "@testcontainers/postgresql": "catalog:testcontainers",
    "@types/node": "^25.9.5",
    "@vitest/coverage-v8": "^4.1.10",
    "@vitest/ui": "^4.1.10",
    "changelogen": "^0.6.2",
    "lefthook": "^2.1.10",
    "listhen": "^1.10.0",
    "oxfmt": "^0.58.0",
    "oxlint": "^1.73.0",
    "oxlint-tsgolint": "^0.24.0",
    "publint": "^0.3.21",
    "testcontainers": "catalog:testcontainers",
    "tsdown": "^0.22.4",
    "typescript": "^6.0.3",
    "unplugin-unused": "^0.5.7",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@cloudflare/workers-types": "catalog:drivers",
    "@electric-sql/pglite": "catalog:drivers",
    "better-sqlite3": "catalog:drivers",
    "drizzle-kit": "catalog:",
    "drizzle-orm": "catalog:",
    "h3": "catalog:",
    "mysql2": "catalog:drivers",
    "postgres": "catalog:drivers"
  },
  "peerDependenciesMeta": {
    "@cloudflare/workers-types": {
      "optional": true
    },
    "@electric-sql/pglite": {
      "optional": true
    },
    "better-sqlite3": {
      "optional": true
    },
    "mysql2": {
      "optional": true
    },
    "postgres": {
      "optional": true
    }
  },
  "packageManager": "pnpm@10.34.4+sha512.8768be55200ae3f2226b6527fcca2687e14bc4e5f12d7721a0f25da3df47915177058648db4177baf348120fa0ba2752d8d8d93f6beaf1fe64ae18da8de961af"
}
